# ── Etsy API ──
ETSY_CLIENT_ID=your_etsy_client_id_here

# ── Serper (Google Lens) ──
SERPER_API_KEY=your_serper_api_key_here

# ── ImgBB (upload image public) ──
IMGBB_API_KEY=your_imgbb_api_key_here

# ── MongoDB ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/finder_niche

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_here

# ── Gemini (niche keywords) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Stripe (paiements) ──
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Resend (emails) ──
RESEND_API_KEY=your_resend_api_key_here

# ── CLIP Service (microservice Python sur HuggingFace Spaces) ──
# Format : https://VOTRE-USERNAME-VOTRE-SPACE-NAME.hf.space
CLIP_SERVICE_URL=https://votre-username-clip-service.hf.space
CLIP_THRESHOLD=0.78

# ── ScraperAPI (AliExpress) ──
SCRAPEAPI_KEY=your_scrapeapi_key_here

# ── Port ──
PORT=3000
